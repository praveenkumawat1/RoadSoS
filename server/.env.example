# Server configuration
PORT=5000

# Frontend origin(s) allowed to call this backend
# Comma-separated list, e.g. https://your-vercel-app.vercel.app,https://your-domain.com
CLIENT_ORIGIN=http://localhost:5173

# Optional: if you prefer a generic CORS list instead of CLIENT_ORIGIN
CORS_ORIGIN=http://localhost:5173

# AI / Messaging providers
GEMINI_API_KEY=
OPENAI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
